# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual Environments ──────────────────────────────────
.venv/
venv/
venv*/
env/
.v1/
dockerlabvenv/
fastapivenv/
streamlitvenv/
actionsvenv/
hvenv/
venv39/
*venv/
*venv*/

# ── Trained Models ────────────────────────────────────────
models/*.pkl
models/*.joblib
