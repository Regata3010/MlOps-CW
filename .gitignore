!models/.gitkeep

# ── Jupyter ───────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Environment & Secrets ─────────────────────────────────
.env
.env.*
*.pem
*.key

# ── Terraform ─────────────────────────────────────────────
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl
crash.log
override.tf
override.tf.json

# ── macOS ─────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Docker ────────────────────────────────────────────────
